{
  "name": "patrimo",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "dev:turbo": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "ci:local": "npm run typecheck && npm run test && npm run build",
    "ready:check": "npm run typecheck && npm run test",
    "secrets:check": "echo See docs/secrets.md — CI runs gitleaks; ensure .env is not committed",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-blockchains": "tsx scripts/seed-blockchains.ts",
    "db:regen": "prisma generate",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
