# Copier vers .env : Copy-Item .env.example .env
# Ne commitez JAMAIS le fichier .env
# Documentation : docs/secrets.md

# ── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL (Docker Compose par défaut)
DATABASE_URL="postgresql://patrimo:patrimo@localhost:5432/patrimo?schema=public"

# ── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Comptes bootstrap (seed) — OBLIGATOIRES pour npm run db:seed ─────────────
# Mots de passe : choisissez des valeurs fortes ; ne les commitez jamais.
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@patrimo.local"
ADMIN_PASSWORD=

DEMO_USERNAME="demo"
DEMO_EMAIL="demo@patrimo.fr"
DEMO_PASSWORD=

# ── Playwright / E2E ─────────────────────────────────────────────────────────
# Par défaut E2E utilise le compte demo (même mot de passe que DEMO_PASSWORD).
E2E_USER="demo"
E2E_PASS=
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"

# ── Clés API marché (serveur uniquement — optionnel en local) ────────────────
# https://finnhub.io/register
FINNHUB_API_KEY=
# CoinGecko Demo API
COINGECKO_API_KEY=

# ── Logo.dev (clé publishable, côté client OK) ───────────────────────────────
# https://www.logo.dev/docs/logo-images/introduction
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# ── Cron intérêts livrets (optionnel) ────────────────────────────────────────
# Bearer token pour POST /api/savings/accrue en mode multi-user
CRON_SECRET=

# ── Divers ───────────────────────────────────────────────────────────────────
# true uniquement sur environnements de démo / e2e (jamais en prod réelle)
ALLOW_DEMO_FALLBACK="false"

# Marque l’instance comme « déployée » pour les garde-fous health (optionnel).
# Sur Vercel, détecté automatiquement via VERCEL=1.
# PATRIMO_DEPLOYED="true"

# NODE_ENV est géré par Next (development | production) — ne pas forcer en local.
