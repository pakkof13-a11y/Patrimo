# Copier vers .env : Copy-Item .env.example .env
# Ne commitez jamais le fichier .env

# PostgreSQL (Docker Compose par défaut)
DATABASE_URL="postgresql://patrimo:patrimo@localhost:5432/patrimo?schema=public"

# Auth.js / NextAuth
AUTH_SECRET="remplacez-par-un-secret-long-et-aleatoire"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# Finnhub (gratuit) — https://finnhub.io/register — serveur uniquement
FINNHUB_API_KEY="votre-cle-finnhub"

# CoinGecko Demo API (serveur uniquement)
COINGECKO_API_KEY="votre-cle-demo-coingecko"

# Logo.dev — clé publishable (safe client-side, utilisée dans les <img>)
# https://www.logo.dev/docs/logo-images/introduction
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY="pk_votre_cle_publishable"

# Optionnel
ALLOW_DEMO_FALLBACK="true"
