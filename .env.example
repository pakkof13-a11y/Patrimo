# Copier vers .env : Copy-Item .env.example .env
# Ne commitez JAMAIS le fichier .env
# Documentation : docs/secrets.md

# ── Base de données ──────────────────────────────────────────────────────────
# PostgreSQL (Docker Compose par défaut)
DATABASE_URL="postgresql://patrimo:patrimo@localhost:5432/patrimo?schema=public"

# ── Auth.js / NextAuth ───────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ── Comptes bootstrap (seed) — OBLIGATOIRES pour npm run db:seed ─────────────
# Mots de passe : choisissez des valeurs fortes ; ne les commitez jamais.
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@patrimo.local"
ADMIN_PASSWORD=

DEMO_USERNAME="demo"
DEMO_EMAIL="demo@patrimo.fr"
DEMO_PASSWORD=

# ── Playwright / E2E ─────────────────────────────────────────────────────────
# Par défaut E2E utilise le compte demo (même mot de passe que DEMO_PASSWORD).
# Le seed e2e n’efface QUE le compte demo — le compte admin n’est plus wipe.
E2E_USER="demo"
E2E_PASS=
# PLAYWRIGHT_BASE_URL="http://127.0.0.1:3000"
# Base isolée recommandée (Playwright ne touchera plus la DB de travail) :
# DATABASE_URL_E2E="postgresql://patrimo:patrimo@localhost:5432/patrimo_e2e?schema=public"
# E2E_SKIP_SEED=1
# PLAYWRIGHT_FORCE_SERVER=1

# ── Clés API marché (serveur uniquement — optionnel en local) ────────────────
# https://finnhub.io/register
FINNHUB_API_KEY=
# CoinGecko Demo (plan Demo) — clé CG-… dashboard https://www.coingecko.com/en/developers/dashboard
# Header : x-cg-demo-api-key · Base : https://api.coingecko.com/api/v3
# Ne pas utiliser une clé Pro ici sans migrer le client vers pro-api + x-cg-pro-api-key
COINGECKO_API_KEY=
# Solana — RPC natif (@solana/web3.js). Le RPC public rate-limite fort (429).
# Recommandé : Helius / QuickNode / Alchemy (endpoint HTTP standard, pas Enhanced API).
# SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
# Délai min entre appels RPC (ms). Défaut 750 sur mainnet-beta public, 150 sinon.
# SOLANA_RPC_MIN_INTERVAL_MS=750
# Historique : max signatures premier run / incrémental (défaut 40/25 public, 80/40 RPC custom)
# SOLANA_INITIAL_SIG_LIMIT=40
# SOLANA_INCREMENTAL_SIG_LIMIT=25

# Zerion Wallet API — multi-chaînes EVM (hors Solana Helius, hors Monero)
# Auth Basic : username = clé, password vide
# Free : 1 req/s, 300 req/jour — throttle 1.1s côté client
# ZERION_API_KEY=zk_64ac4bfaf37e4075bc7709e0ce2357d2

# ── Logo.dev (clé publishable, côté client OK) ───────────────────────────────
# https://www.logo.dev/docs/logo-images/introduction
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=

# ── Cron intérêts livrets (optionnel) ────────────────────────────────────────
# Bearer token pour POST /api/savings/accrue en mode multi-user
CRON_SECRET=

# ── Divers ───────────────────────────────────────────────────────────────────
# true uniquement sur environnements de démo / e2e (jamais en prod réelle)
ALLOW_DEMO_FALLBACK="false"

# Marque l’instance comme « déployée » pour les garde-fous health (optionnel).
# Sur Vercel, détecté automatiquement via VERCEL=1.
# PATRIMO_DEPLOYED="true"

# NODE_ENV est géré par Next (development | production) — ne pas forcer en local.
